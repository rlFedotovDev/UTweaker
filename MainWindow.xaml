<controls:MicaWindow x:Class="MakuTweakerNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MakuTweakerNew"
        xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        mc:Ignorable="d" ui:ThemeManager.RequestedTheme="Default"
        Title="MakuTweaker"
        Height="675" MinHeight="675" MaxHeight="675"
        Width="1062" MinWidth="1062" MaxWidth="1062"
        SystemBackdropType="Tabbed" WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        Loaded="MicaWindow_Loaded"
        FocusVisualStyle="{x:Null}"
        Focusable="False"
        Topmost="False" Icon="/assets/images/makut.png">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="0"
                      CaptionHeight="32"
                      CornerRadius="0"
                      GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:NavigationView x:Name="NavigationView_Root" 
                           Grid.Row="0"
                           IsBackButtonVisible="Collapsed" 
                           IsPaneToggleButtonVisible="False" 
                           IsSettingsVisible="False"
                           ScrollViewer.VerticalScrollBarVisibility="Disabled"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                           OpenPaneLength="290" SelectionChanged="NavigationView_SelectionChanged"
                           Background="Transparent">

            <ui:NavigationView.PaneHeader>
                <TextBlock Text="MakuTweaker" 
                           FontSize="36" 
                           FontFamily="Segoe UI Semibold" 
                           HorizontalAlignment="Center"/>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.Resources>
                <Style TargetType="ScrollViewer" x:Key="NavigationViewMenuItemsScrollViewerStyle">
                    <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                    <Setter Property="CanContentScroll" Value="False"/>
                </Style>

                <Style TargetType="ScrollViewer">
                    <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                </Style>

                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewPaneContentMargin">0</Thickness>

                <Style TargetType="ui:NavigationViewItem">
                    <Setter Property="Width" Value="{Binding OpenPaneLength, RelativeSource={RelativeSource AncestorType=ui:NavigationView}}" />
                    <Setter Property="Height" Value="36" />
                    <Setter Property="MinHeight" Value="36" />
                </Style>
            </ui:NavigationView.Resources>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="c1" Tag="exp" Content="Explorer and Desktop">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c2" Tag="wu" Content="Windows Update">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Sync}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c3" Tag="sys" Content="System and Recovery">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.System}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c4" Tag="uwp" Content="Remove UWP Apps">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c5" Tag="per" Content="Personalization">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c6" Tag="adv" Content="Advanced">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.List}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c7" Tag="quick" Content="Quick Windows Setup">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ViewAll}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c8" Tag="compon" Content="Windows Components">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Component}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c9" Tag="act" Content="Windows Activation">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Permissions}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c10" Tag="perf" Content="Performance">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.SpeedHigh}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c11" Tag="sat" Content="Shutdown Timer">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.History}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c12" Tag="pmgr" Content="Process Management">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.AllApps}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="c13" Tag="pci" Content="PC Information">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Info}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:Frame x:Name="MainFrame" Navigated="MainFrame_Navigated" />

        </ui:NavigationView>

        <Border Grid.Row="1" 
                Height="36" 
                Background="#0AFFFFFF" 
                BorderBrush="#22FFFFFF" 
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="status" FontSize="12" Foreground="#88FFFFFF" VerticalAlignment="Center" Margin="15,0,0,0" Visibility="Collapsed"/>

                <StackPanel x:Name="ABCB" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Stretch" 
                            Margin="0,0,0,0">

                    <Button x:Name="rexplorer" 
                            Click="rexplorer_Click" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            VerticalAlignment="Stretch" 
                            Padding="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Refresh}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="rexplorerText" Text="Restart Explorer" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="16" Fill="#44FFFFFF" VerticalAlignment="Center" Margin="2,0,2,0" />

                    <Button x:Name="settingsButton" 
                            Click="settingsButton_Click" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            VerticalAlignment="Stretch" 
                            Padding="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="settingsText" Text="Settings &amp; About" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</controls:MicaWindow>