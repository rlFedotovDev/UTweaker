<Page x:Class="MakuTweakerNew.SettingsAbout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MakuTweakerNew"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d"
      d:DesignHeight="702" d:DesignWidth="704.04"
      Title="Explorer">

    <Grid>
        <Image Source="assets/images/MakuTweakerAbout.png" HorizontalAlignment="Center" VerticalAlignment="Top" Width="498" Height="100" Margin="0,166,0,0"/>
        <TextBlock x:Name="credL" HorizontalAlignment="Left" Margin="30,285,0,0" TextWrapping="Wrap" Text="credL" VerticalAlignment="Top" FontSize="24" FontFamily="Segoe UI Semibold"/>
        <TextBlock x:Name="credN" Margin="380,285,0,0" TextWrapping="Wrap" Text="credN" VerticalAlignment="Top" FontSize="24" FontFamily="Segoe UI Semibold" HorizontalAlignment="Left" Width="296"/>

        <TextBlock x:Name="credLang" HorizontalAlignment="Left" Margin="30,380,0,0" TextWrapping="Wrap" Text="credLang" VerticalAlignment="Top" FontSize="24" FontFamily="Segoe UI Semibold" Visibility="Hidden"/>
        <TextBlock x:Name="credLangtext" Margin="380,380,0,0" TextWrapping="Wrap" Text="credLangtext" VerticalAlignment="Top" FontSize="24" FontFamily="Segoe UI Semibold" HorizontalAlignment="Left" Width="296" Visibility="Hidden"/>

        <controls:Button x:Name="web" Content="Official Website" Margin="30,504,452,0" Height="38" Click="Button_Click" VerticalAlignment="Top"/>
        <Image HorizontalAlignment="Left" Height="74" Margin="639,495,0,0" VerticalAlignment="Top" Source="/assets/images/hand_heart_donate_icon.png" Width="75" MouseLeftButtonUp="Image_MouseLeftButtonUp" Cursor="Hand"/>
        <Image HorizontalAlignment="Left" Height="74" Margin="549,495,0,0" VerticalAlignment="Top" Source="/assets/images/Telegram_2019_Logo.svg.png" Width="75" MouseLeftButtonUp="Image_MouseLeftButtonUp_2" Cursor="Hand"/>
        <Image HorizontalAlignment="Left" Height="74" Margin="459,495,0,0" VerticalAlignment="Top" Source="/assets/images/You-Tube-16.png" Width="75" MouseLeftButtonUp="Image_MouseLeftButtonUp_3" Cursor="Hand"/>
        <TextBlock x:Name="label" HorizontalAlignment="Left" Margin="24,11,0,0" TextWrapping="Wrap" Text="Settings" VerticalAlignment="Top" FontSize="32" FontFamily="Segoe UI Semibold"/>
        <TextBlock x:Name="langL" HorizontalAlignment="Left" Margin="30,70,0,0" TextWrapping="Wrap" Text="Program Language" VerticalAlignment="Top" FontSize="16"/>
        <ComboBox x:Name="lang" HorizontalAlignment="Left" Padding="10,0,0,0" Margin="30,100,0,0" FontSize="14"  Width="177" VerticalAlignment="Top" MinWidth="177" MaxWidth="177" SelectionChanged="lang_SelectionChanged">
            <ComboBoxItem Content="English [EN]" Tag="en"/>
            <ComboBoxItem Content="Русский [RU]" Tag="ru"/>
            <ComboBoxItem Content="Українська [UA]" Tag="uk"/>
            <ComboBoxItem Content="Беларуская [BE]" Tag="be"/>
            <ComboBoxItem Content="Қазақша [KK]" Tag="kk"/>
            <ComboBoxItem Content="Čeština [CS]" Tag="cs"/>
            <ComboBoxItem Content="Deutsch [DE]" Tag="de"/>
            <ComboBoxItem Content="Français [FR]" Tag="fr"/>
            <ComboBoxItem Content="Español [ES]" Tag="es"/>
            <ComboBoxItem Content="Italiano [IT]" Tag="it"/>
            <ComboBoxItem Content="Português [PT]" Tag="pt"/>
            <ComboBoxItem Content="Suomi [FI]" Tag="fi"/>
            <ComboBoxItem Content="Eesti [ET]" Tag="et"/>
            <ComboBoxItem Content="Latviešu [LV]" Tag="lv"/>
            <ComboBoxItem Content="Polski [PL]" Tag="pl"/>
            <ComboBoxItem Content="Azərbaycan [AZ]" Tag="az"/>
            <ComboBoxItem Content="Türkçe [TR]" Tag="tr"/>
            <ComboBoxItem Content="简体中文 [ZH-CN]" Tag="zh"/>
            <ComboBoxItem Content="繁體中文 [ZH-TW]" Tag="tw"/>
            <ComboBoxItem Content="日本語 [JA]" Tag="ja"/>
            <ComboBoxItem Content="한국어 [KO]" Tag="ko"/>
            <ComboBoxItem Content="Tiếng Việt [VI]" Tag="vi"/>
            <ComboBoxItem Content="ไทย [TH]" Tag="th"/>
            <ComboBoxItem Content="Bahasa Indonesia [ID]" Tag="id"/>
            <ComboBoxItem Content="Tagalog [TL]" Tag="tl"/>
            <ComboBoxItem Content="हिन्दी [HI]" Tag="hi"/>
        </ComboBox>
        <TextBlock x:Name="copyleft" HorizontalAlignment="Left" Margin="30,551,0,0" TextWrapping="Wrap" Text="Mark Adderly / 2023 - 2026" VerticalAlignment="Top" FontSize="24" FontFamily="Segoe UI Semilight"/>
        <TextBlock x:Name="themeL" HorizontalAlignment="Left" Margin="220,70,0,0" TextWrapping="Wrap" Text="Theme" VerticalAlignment="Top" FontSize="16"/>
        <ComboBox x:Name="theme" HorizontalAlignment="Left" Margin="220,100,0,0" FontSize="14"  Width="177" VerticalAlignment="Top" MinWidth="177" MaxWidth="177" SelectionChanged="theme_SelectionChanged">
            <ComboBoxItem Content=" Light" x:Name="l"/>
            <ComboBoxItem Content=" Dark" x:Name="d"/>
        </ComboBox>
        <TextBlock x:Name="styleL" HorizontalAlignment="Left" Margin="410,70,0,0" TextWrapping="Wrap" Text="Style" VerticalAlignment="Top" FontSize="16"/>
        <ComboBox x:Name="style" HorizontalAlignment="Left" Margin="410,100,0,0" FontSize="14"  Width="177" VerticalAlignment="Top" MinWidth="177" MaxWidth="177" SelectionChanged="style_SelectionChanged">
            <ComboBoxItem Content=" Mica"/>
            <ComboBoxItem Content=" Mica Alt (Default)"/>
            <ComboBoxItem Content=" Acrylic"/>
            <ComboBoxItem Content=" Off" x:Name="off"/>
        </ComboBox>
    </Grid>
</Page>
