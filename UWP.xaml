        <ui:ToggleSwitch IsEnabled="False" Margin="24,434,479,0" OnContent="People" OffContent="People" VerticalAlignment="Top" HorizontalAlignment="Stretch" x:Name="u25" Grid.Row="1" Opacity="0" IsTabStop="False"/>
        <ui:ToggleSwitch IsEnabled="False" Margin="24,146,0,0" OnContent="Skype" OffContent="Skype" VerticalAlignment="Top" x:Name="u26" Grid.Row="1" Opacity="0" IsTabStop="False"/>
