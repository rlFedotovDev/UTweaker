        <ui:ToggleSwitch IsEnabled="False" Margin="252,465,251,0" OnContent="Movies and TV" OffContent="Movies and TV" VerticalAlignment="Top" HorizontalAlignment="Stretch" x:Name="u16" Grid.Row="1" Opacity="0" IsTabStop="False"/>
