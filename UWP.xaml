        <TextBlock x:Name="info2"  HorizontalAlignment="Left" Margin="24,39,0,0" TextWrapping="Wrap" Text="Please note: This apps will not be removed for all users." VerticalAlignment="Top" FontSize="18" FontFamily="Segoe UI" Grid.Row="1"/>
        <ui:ToggleSwitch IsEnabled="False" Margin="24,82,479,0" OnContent="Windows Mixed Reality" OffContent="Windows Mixed Reality" VerticalAlignment="Top" HorizontalAlignment="Stretch" x:Name="u1" Grid.Row="1" Opacity="0" IsTabStop="False"/>
