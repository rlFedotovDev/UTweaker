        <ui:ToggleSwitch IsEnabled="False" Margin="24,338,479,0" OnContent="OneNote" OffContent="OneNote" VerticalAlignment="Top" HorizontalAlignment="Stretch" x:Name="u14" Grid.Row="1" Opacity="0" IsTabStop="False"/>
