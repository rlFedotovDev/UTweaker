        <ui:ToggleSwitch IsEnabled="False" Margin="252,210,251,0" OnContent="News" OffContent="News" VerticalAlignment="Top" HorizontalAlignment="Stretch" x:Name="u18" Grid.Row="1" Opacity="0" IsTabStop="False"/>
