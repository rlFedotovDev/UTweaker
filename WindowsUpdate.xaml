<Page x:Class="MakuTweakerNew.WindowsUpdate"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MakuTweakerNew"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" 
      d:DesignHeight="702" d:DesignWidth="704.04"
      Title="Desktop">

    <Grid Grid.IsSharedSizeScope="True">
        <StackPanel>
            <TextBlock x:Name="lab" HorizontalAlignment="Left" Margin="24,11,0,0" TextWrapping="Wrap" Text="Windows Update" VerticalAlignment="Top" FontSize="32" FontFamily="Segoe UI Semibold"/>

            <TextBlock x:Name="pausel" HorizontalAlignment="Left" Margin="24,14,0,0" TextWrapping="Wrap" Text="Pause Windows Update Service" VerticalAlignment="Top" FontSize="16"/>

            <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="WinUpdateButtons"/>
                </Grid.ColumnDefinitions>
                <controls:Button x:Name="pause" Padding="20,5" Content="Pause" Height="28" Click="pause_Click"/>
            </Grid>

            <TextBlock x:Name="l7" HorizontalAlignment="Left" Margin="24,10,0,0" TextWrapping="Wrap" Text="Clean Windows Update Cache" VerticalAlignment="Top" FontSize="16"/>

            <Grid HorizontalAlignment="Left" Margin="24,5,0,0" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="WinUpdateButtons"/>
                </Grid.ColumnDefinitions>
                <controls:Button x:Name="wupd" Padding="20,5" Content="Clean" Height="28" Click="wupd_Click"/>
            </Grid>

            <TextBlock x:Name="blockL" HorizontalAlignment="Left" Margin="24,10,0,0" TextWrapping="Wrap" Text="Block Updates on a Specific Version of Windows" VerticalAlignment="Top" FontSize="16"/>

            <StackPanel Orientation="Horizontal" Margin="24,5,0,0">
                <ComboBox x:Name="wu4" FontSize="14" Width="177" VerticalAlignment="Center" SelectionChanged="wu4_SelectionChanged">
                    <ComboBoxItem Content=" 1607 // 14393" x:Name="u1607"/>
                    <ComboBoxItem Content=" 1709 // 16299" x:Name="u1709"/>
                    <ComboBoxItem Content=" 1809 // 17763" x:Name="u1809"/>
                    <ComboBoxItem Content=" 1909 // 18363" x:Name="u1909"/>
                    <ComboBoxItem Content=" 2004 // 19041" x:Name="u2004"/>
                    <ComboBoxItem Content=" 20H2 // 19042" x:Name="u20H2"/>
                    <ComboBoxItem Content=" 21H2 // 19044, 22000" x:Name="u21H2"/>
                    <ComboBoxItem Content=" 22H2 // 19045, 22621" IsSelected="True" x:Name="u22H2"/>
                    <ComboBoxItem Content=" 23H2 // 22631" x:Name="u23H2"/>
                    <ComboBoxItem Content=" 24H2 // 26100" x:Name="u24H2"/>
                    <ComboBoxItem Content=" 25H2 // 26200" x:Name="u25H2"/>
                    <ComboBoxItem Content=" 26H2 // 26300" x:Name="u26H2"/>
                </ComboBox>

                <Grid Margin="10,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="WinUpdateButtons"/>
                    </Grid.ColumnDefinitions>
                    <controls:Button x:Name="block" Content="Block" Height="30" Click="Button_Click"/>
                </Grid>
            </StackPanel>

            <ui:ToggleSwitch x:Name="wu1" Header="Disable Windows Update" Margin="24,14,0,0" VerticalAlignment="Top" FontSize="16" Toggled="ToggleSwitch_Toggled"/>
            <ui:ToggleSwitch x:Name="wu2" Header="Disable Driver Installation via Windows Update" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16" Toggled="ToggleSwitch_Toggled_1"/>
            <ui:ToggleSwitch x:Name="wu6" Header="Disable Reserved Storage for Updates" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16" Toggled="wu6_Toggled"/>

            <StackPanel x:Name="loadingPanel" Margin="0,30,0,30" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" Visibility="Visible">
                <ui:ProgressRing x:Name="ring" IsActive="False" Width="60" Height="60" HorizontalAlignment="Center"/>
                <TextBlock x:Name="t" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Очистка кэша..." FontSize="14" FontFamily="Segoe UI" Margin="0,12,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>